# Database
MONGODB_URI=mongodb://localhost:27017/vaniki-crop

# Auth Settings
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here

# MSG91/OTP
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id
MSG91_DLT_TEMPLATE_ID=your_msg91_dlt_template_id

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_WEBHOOK_URL=https://api.vanikicrop.com/api/payments/webhook

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_PRESET=vaniki_web_upload
CLOUDINARY_EAGER_TRANSFORMATIONS=f_auto,q_auto,w_1200

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Vaniki Crop" <no-reply@vanikicrop.com>
CONTACT_TO_EMAIL=support@vanikicrop.com

# App Info
WHATSAPP_NUMBER=919876543210
STORE_NAME="Vaniki Crop"
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
VITE_API_URL=http://localhost:5000/api
VITE_SITE_URL=http://localhost:5173
VITE_WHATSAPP_LINK=https://wa.link/example

# Super Admin Credentials
SUPER_ADMIN_EMAIL=superadmin@vanikicrop.com
SUPER_ADMIN_PASSWORD=superadmin_secure_password
